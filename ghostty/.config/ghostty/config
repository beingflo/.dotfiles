theme = 0x96f
adjust-cursor-thickness = 200%
cursor-color = #FFFFFF
cursor-style-blink = false
font-size = 15
macos-titlebar-style = tabs
macos-window-shadow = false
split-divider-color = #F0f0f0

keybind = cmd+h=goto_split:left
keybind = cmd+l=goto_split:right
keybind = cmd+k=goto_split:up
keybind = cmd+j=goto_split:down

keybind = cmd+[=previous_tab
keybind = cmd+]=next_tab

working-directory = home
window-inherit-working-directory = false
tab-inherit-working-directory = false

command = /opt/homebrew/bin/fish
